      "cell_type": "code",
      "source": [
        "# Cell 3: 跑 MNLI validation 確認 baseline accuracy\n",
        "from datasets import load_dataset\n",
        "import torch\n",
        "from tqdm import tqdm\n",
        "\n",
        "# MNLI 有兩個 validation set: matched 和 mismatched\n",
        "# matched 是同 domain, mismatched 是跨 domain. 我們先跑 matched\n",
        "dataset = load_dataset(\"nyu-mll/glue\", \"mnli\", split=\"validation_matched\")\n",
        "print(f\"Validation samples: {len(dataset)}\")\n",
        "print(f\"範例: {dataset[0]}\")\n",
        "\n",
        "# 跑 inference, 算 accuracy\n",
        "correct = 0\n",
        "total = 0\n",
        "BATCH_SIZE = 32\n",
        "\n",
        "# 為了快速確認,先跑前 500 筆;等下你可以改成 len(dataset) 跑全部\n",
        "SAMPLES_TO_RUN = 500\n",
        "\n",
        "with torch.no_grad():\n",
        "    for i in tqdm(range(0, SAMPLES_TO_RUN, BATCH_SIZE)):\n",
        "        batch = dataset[i:i+BATCH_SIZE]\n",
        "        inputs = tokenizer(\n",
        "            batch[\"premise\"],\n",
        "            batch[\"hypothesis\"],\n",
        "            padding=True,\n",
        "            truncation=True,\n",
        "            max_length=128,\n",
        "            return_tensors=\"pt\"\n",
        "        ).to(\"cuda\")\n",
        "\n",
        "        outputs = model(**inputs)\n",
        "        preds = outputs.logits.argmax(dim=-1).cpu()\n",
        "        labels = torch.tensor(batch[\"label\"])\n",
        "\n",
        "        # 注意: HuggingFace 的 label 順序可能跟模型不同, 需要對齊\n",
        "        # ishan/bert-base-uncased-mnli: 0=contradiction, 1=neutral, 2=entailment\n",
        "        # MNLI dataset:                    0=entailment,    1=neutral, 2=contradiction\n",
        "        # 所以要 swap 0 和 2\n",
        "        label_map = torch.tensor([1, 2, 0])\n",
        "        labels_aligned = label_map[labels]\n",
        "\n",
        "        correct += (preds == labels_aligned).sum().item()\n",
        "        total += len(labels)\n",
        "\n",
        "print(f\"\\nAccuracy on {total} samples: {correct/total*100:.2f}%\")\n",
        "print(\"預期: 84-85%\")"
      ],
