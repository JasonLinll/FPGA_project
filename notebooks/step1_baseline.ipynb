    {
      "cell_type": "code",
      "source": [
        "# Cell 4: 用 forward hook dump 出 Q/K/V (存到 Google Drive)\n",
        "import numpy as np\n",
        "import os\n",
        "\n",
        "# 我們要 hook 的目標層: encoder layer 3 的 self-attention\n",
        "target_layer_idx = 3\n",
        "target_layer = model.bert.encoder.layer[target_layer_idx].attention.self\n",
        "\n",
        "# 容器存抓到的中間值\n",
        "captured = {}\n",
        "\n",
        "def hook_fn(module, inputs, outputs):\n",
        "    # inputs[0] 是 hidden_states, shape [batch, seq, hidden=768]\n",
        "    hidden_states = inputs[0]\n",
        "\n",
        "    # 重新計算 Q/K/V (因為 module 內部不直接暴露這些)\n",
        "    Q = module.query(hidden_states)  # [batch, seq, hidden]\n",
        "    K = module.key(hidden_states)\n",
        "    V = module.value(hidden_states)\n",
        "\n",
        "    # reshape 成多頭格式: [batch, heads, seq, head_dim]\n",
        "    B, S, H = Q.shape\n",
        "    num_heads = module.num_attention_heads\n",
        "    head_dim = H // num_heads\n",
        "\n",
        "    Q = Q.view(B, S, num_heads, head_dim).permute(0, 2, 1, 3)\n",
        "    K = K.view(B, S, num_heads, head_dim).permute(0, 2, 1, 3)\n",
        "    V = V.view(B, S, num_heads, head_dim).permute(0, 2, 1, 3)\n",
        "\n",
        "    captured[\"Q\"] = Q.detach().cpu().numpy()\n",
        "    captured[\"K\"] = K.detach().cpu().numpy()\n",
        "    captured[\"V\"] = V.detach().cpu().numpy()\n",
        "    captured[\"attention_mask\"] = inputs[1].detach().cpu().numpy() if len(inputs) > 1 and inputs[1] is not None else None\n",
        "\n",
        "handle = target_layer.register_forward_hook(hook_fn)\n",
        "\n",
        "# 拿一筆 MNLI 樣本來跑\n",
        "sample = dataset[0]\n",
        "inputs = tokenizer(\n",
        "    sample[\"premise\"],\n",
        "    sample[\"hypothesis\"],\n",
        "    padding=\"max_length\",  # 重要: padding 到固定長度,方便之後 RTL 用\n",
        "    truncation=True,\n",
        "    max_length=128,\n",
        "    return_tensors=\"pt\"\n",
        ").to(\"cuda\")\n",
        "\n",
        "with torch.no_grad():\n",
        "    _ = model(**inputs)\n",
        "\n",
        "handle.remove()  # 用完移除 hook\n",
        "\n",
        "# 印出形狀確認\n",
        "print(f\"Q shape: {captured['Q'].shape}  (batch, heads, seq, head_dim)\")\n",
        "print(f\"K shape: {captured['K'].shape}\")\n",
        "print(f\"V shape: {captured['V'].shape}\")\n",
        "\n",
        "# 看一下 Q 的數值分佈\n",
        "Q = captured[\"Q\"]\n",
        "print(f\"\\nQ 數值統計:\")\n",
        "print(f\"  min:  {Q.min():.4f}\")\n",
        "print(f\"  max:  {Q.max():.4f}\")\n",
        "print(f\"  mean: {Q.mean():.4f}\")\n",
        "print(f\"  std:  {Q.std():.4f}\")\n",
        "\n",
        "# 存檔到 Google Drive 的「大專生計畫」資料夾\n",
        "save_path = f\"{SAVE_DIR}/layer{target_layer_idx}_sample0.npz\"\n",
        "np.savez(\n",
        "    save_path,\n",
        "    Q=captured[\"Q\"],\n",
        "    K=captured[\"K\"],\n",
        "    V=captured[\"V\"],\n",
        ")\n",
        "print(f\"\\n已存檔到: {save_path}\")\n",
        "\n",
        "# 確認檔案真的有寫進去\n",
        "file_size_kb = os.path.getsize(save_path) / 1024\n",
        "print(f\"檔案大小: {file_size_kb:.1f} KB\")"
      ],
