      "source": [
        "# Cell 1: 確認環境\n",
        "import torch\n",
        "print(f\"PyTorch version: {torch.__version__}\")\n",
        "print(f\"CUDA available: {torch.cuda.is_available()}\")\n",
        "print(f\"Device: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'CPU'}\")\n",
        "\n",
        "# 安裝 transformers 和 datasets (Colab 預設沒裝)\n",
        "!pip install -q transformers datasets evaluate\n",
        "print(\"\\n套件安裝完成\")"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Cell 2: 載入已經在 MNLI 上 fine-tune 好的 BERT-Base\n",
        "from transformers import AutoTokenizer, AutoModelForSequenceClassification\n",
        "import torch\n",
        "\n",
        "# 直接用 HuggingFace 上 fine-tune 好的版本,省下自己訓練的時間\n",
        "MODEL_NAME = \"ishan/bert-base-uncased-mnli\"\n",
        "\n",
        "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
        "model = AutoModelForSequenceClassification.from_pretrained(MODEL_NAME)\n",
        "model = model.to(\"cuda\")\n",
        "model.eval()  # 推論模式,不算梯度\n",
        "\n",
        "print(f\"模型: {MODEL_NAME}\")\n",
        "print(f\"參數量: {sum(p.numel() for p in model.parameters()) / 1e6:.1f}M\")\n",
        "print(f\"標籤對應: {model.config.id2label}\")\n",
        "print(f\"Attention layers: {model.config.num_hidden_layers}\")\n",
        "print(f\"Attention heads per layer: {model.config.num_attention_heads}\")\n",
        "print(f\"Head dim: {model.config.hidden_size // model.config.num_attention_heads}\")"
      ],
